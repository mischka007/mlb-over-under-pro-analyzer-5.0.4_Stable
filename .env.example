# Beide Keys sind optional und kostenlos erhältlich. Ohne sie funktioniert
# der Analyzer vollständig weiter — Wetter bzw. Quoten/Markt bleiben dann
# manuell zu befüllende Felder statt automatisch geladen zu werden.
#
# Alternative: Du kannst die Keys auch direkt in der App über den
# Setup-Assistenten eintragen (dort werden sie im Browser gespeichert und
# müssen nicht in dieser Datei stehen). Diese .env-Variablen dienen als
# Fallback für Entwickler, die die App stattdessen per Build-Konfiguration
# vorkonfigurieren möchten.

# https://openweathermap.org/api (kostenloser Tarif reicht)
VITE_OPENWEATHER_API_KEY=

# https://the-odds-api.com (kostenloser Tarif: 500 Requests/Monat)
VITE_ODDS_API_KEY=
