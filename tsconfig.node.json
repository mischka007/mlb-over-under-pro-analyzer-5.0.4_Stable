    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts"
  ]
